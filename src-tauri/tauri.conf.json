{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MineBench Client",
  "version": "0.7.6",
  "identifier": "cloud.minebench.client",
  "build": {
    "frontendDist": "../web-dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MineBench Client",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
        "../Miner/**/*"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
