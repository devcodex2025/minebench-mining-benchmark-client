{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MineBench Client",
  "version": "0.8.10",
  "identifier": "cloud.minebench.client",
  "build": {
    "frontendDist": "../web-dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:prod"
  },
  "app": {
    "windows": [
      {
        "title": "MineBench Client",
        "width": 1024,
        "height": 768,
        "minWidth": 920,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:* https://minebench.cloud https://backend.minebench.cloud https://api.mainnet-beta.solana.com; img-src 'self' asset: http://asset.localhost data: blob:; media-src 'self' asset: http://asset.localhost blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../Miner/**/*"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
