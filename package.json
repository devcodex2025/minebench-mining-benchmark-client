{
  "name": "MineBench-Client",
  "private": true,
  "version": "0.8.14",
  "productName": "MineBench Client",
  "description": "Mining benchmark desktop client with native Wayland support.",
  "author": "MineBench Team",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --mode development",
    "dev:prod": "vite --mode production",
    "sync:version": "node ./scripts/update-tauri-version.cjs",
    "prebuild": "npm run sync:version",
    "pretauri:dev": "npm run sync:version",
    "pretauri:build": "npm run sync:version",
    "clean": "rimraf dist web-dist",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:prod": "vite build --mode production",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "dist:win": "npm run tauri:build -- --target x86_64-pc-windows-msvc",
    "dist:mac": "npm run build:prod && tauri build --target universal-apple-darwin",
    "dist:linux": "npm run build:prod && tauri build --target x86_64-unknown-linux-gnu",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.3",
    "@hugeicons/react": "^1.1.6",
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.76.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.2.1",
    "tailwind-merge": "^3.4.0",
    "three": "^0.161.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tauri-apps/cli": "^2.11.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/three": "^0.165.0",
    "@vitejs/plugin-react": "^5.0.3",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "png-to-ico": "^2.0.0",
    "postcss": "^8.5.6",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.7",
    "wait-on": "^9.0.1"
  },
  "publish": {
    "provider": "github",
    "owner": "devcodex2025",
    "repo": "minebench-mining-benchmark-client"
  },
  "overrides": {
    "bn.js": "5.2.3"
  }
}
